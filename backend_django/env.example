# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this-in-production
# Set to False in production
DEBUG=True
# Comma-separated list of allowed hosts. In dev with DEBUG=True this is ignored (defaults to *).
# Example for production: ALLOWED_HOSTS=api.yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Dev (default — SQLite, no setup needed):
DATABASE_URL=sqlite:///db.sqlite3
# Production (PostgreSQL example):
# DATABASE_URL=postgres://user:password@host:5432/dbname
# Render/Railway/Fly: set DATABASE_URL in their dashboard, leave this line commented out

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# IMPORTANT: This MUST exactly match what the frontend sends to Google and what's registered in Google Console
# For local dev: http://127.0.0.1:8000/auth/google/callback
# For production: https://your-domain.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
APP_JWT_SECRET=your-jwt-secret-here-change-this-in-production

# Security (set all to True in production behind HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
# HSTS: set to 31536000 (1 year) in production once HTTPS is confirmed working
SECURE_HSTS_SECONDS=0

# CORS
# In dev (DEBUG=True) all origins are allowed automatically.
# In production set this to your frontend's exact origin(s):
# CORS_ALLOWED_ORIGINS=https://yourapp.com,https://www.yourapp.com
CORS_ALLOWED_ORIGINS=

# Email Configuration for OTP Password Reset
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mhtguide@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
# Note: You need to generate an App Password from your Google Account settings
# Go to: Google Account > Security > 2-Step Verification > App passwords

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/django.log

# API Rate Limiting
# Tune without redeploying by changing these env vars
THROTTLE_RATE_ANON=100/hour
THROTTLE_RATE_USER=1000/hour
# Auth endpoints (Google login, OTP request/verify/reset) — stricter
THROTTLE_RATE_AUTH=10/hour
# Redis cache for throttle counters across multiple workers (optional in dev)
# CACHE_URL=redis://localhost:6379/0
