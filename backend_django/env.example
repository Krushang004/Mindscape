# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database (for production, consider PostgreSQL)
DATABASE_URL=sqlite:///db.sqlite3

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# IMPORTANT: This MUST exactly match what the frontend sends to Google and what's registered in Google Console
# For local dev: http://127.0.0.1:8000/auth/google/callback
# For production: https://your-domain.com/auth/google/callback
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
APP_JWT_SECRET=your-jwt-secret-here-change-this-in-production

# Security
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# CORS
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000

# Email Configuration for OTP Password Reset
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mhtguide@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password-here
# Note: You need to generate an App Password from your Google Account settings
# Go to: Google Account > Security > 2-Step Verification > App passwords

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/django.log

# API Rate Limiting
REST_FRAMEWORK_THROTTLE_RATE_ANON=100/hour
REST_FRAMEWORK_THROTTLE_RATE_USER=1000/hour
